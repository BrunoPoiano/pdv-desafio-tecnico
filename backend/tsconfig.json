{
	"compilerOptions": {
		"target": "ES2024",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2024"],
		"outDir": "./dist",
		"rootDir": "./src",

		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,

		"esModuleInterop": true,
		"skipLibCheck": true,

		"sourceMap": true,
		"declaration": true,

		"types": ["node", "multer"]
	},
	"include": ["src"]
}
